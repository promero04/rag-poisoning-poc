# Configuración del entorno RAG Poisoning PoC
# Copiar a .env y ajustar valores

# ── Selección de LLM ──────────────────────────────────────────────────────────
# Opciones: "ollama" | "openai" | "none" (solo recuperación, sin generación)
LLM_PROVIDER=ollama

# ── Ollama (LLM local, recomendado) ───────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI (alternativa con API key) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Configuración ChromaDB ────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=rag_baseline

# ── Parámetros de recuperación ────────────────────────────────────────────────
RETRIEVAL_K=3           # Número de chunks recuperados por query
CHUNK_SIZE=500          # Tamaño de chunk en caracteres
CHUNK_OVERLAP=50        # Overlap entre chunks
